    "aulas": [
        {
            "id": "aula-001",
            "titulo": "Como Desenhar Olhos de Anime",
            "descricao": "Aprenda o passo a passo para criar olhos expressivos no estilo anime, desde o formato básico até os detalhes de brilho e sombra.",
            "categoria_aula": "Técnicas Básicas",
            "imagem_capa": "https://placehold.co/400x300/3B82F6/FFFFFF?text=Olhos+Anime",
            "conteudo": [
                {
                    "tipo": "texto",
                    "titulo": "Passo 1: O Formato Básico",
                    "texto": "Comece desenhando um círculo leve com lápis. Este será o contorno do olho. Não aperte muito o lápis, pois vamos apagar depois. O tamanho do círculo define se o olho será grande (estilo shonen) ou mais realista (estilo seinen)."
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/E0E7FF/3B82F6?text=Passo+1:+Círculo+Básico",
                    "legenda": "Desenhe um círculo leve como base do olho"
                },
                {
                    "tipo": "texto",
                    "titulo": "Passo 2: A Íris e a Pupila",
                    "texto": "Dentro do círculo, desenhe outro círculo menor para a íris. No centro, faça um círculo ainda menor para a pupila. Deixe um pequeno espaço branco no topo da íris — isso dá mais realismo ao olho."
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/E0E7FF/3B82F6?text=Passo+2:+Íris+e+Pupila",
                    "legenda": "Adicione íris, pupila e reflexo de luz"
                },
                {
                    "tipo": "texto",
                    "titulo": "Passo 3: Brilho e Sombra",
                    "texto": "O segredo dos olhos de anime está no brilho! Desenhe um círculo branco (reflexo de luz) no canto superior da íris. Preencha a pupila de preto e faça um degradê na íris, mais escuro nas bordas e mais claro no centro."
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/E0E7FF/3B82F6?text=Passo+3:+Brilho+e+Sombra",
                    "legenda": "Adicione brilho e sombra para dar vida ao olho"
                },
                {
                    "tipo": "texto",
                    "titulo": "Passo 4: Cílios e Sobrancelha",
                    "texto": "Desenhe os cílios superiores grossos e curvados para cima. Os cílios inferiores são mais finos. Acima do olho, desenhe a sobrancelha com traços firmes. A posição da sobrancelha muda a expressão do personagem!"
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/E0E7FF/3B82F6?text=Passo+4:+Cílios+e+Sobrancelha",
                    "legenda": "Finalize com cílios e sobrancelha"
                }
            ],
            "ordem": 1,
            "ativo": true
        },
        {
            "id": "aula-002",
            "titulo": "Sombreamento com Lápis de Cor",
            "descricao": "Técnicas de sombreamento para dar volume e profundidade aos seus desenhos usando lápis de cor.",
            "categoria_aula": "Técnicas Básicas",
            "imagem_capa": "https://placehold.co/400x300/22C55E/FFFFFF?text=Sombreamento",
            "conteudo": [
                {
                    "tipo": "texto",
                    "titulo": "Técnica do Degradê",
                    "texto": "A técnica do degradê é a base do sombreamento. Comece pressionando forte o lápis em uma área e vá diminuindo a pressão gradualmente. Use movimentos circulares suaves para não deixar marcas de traço aparentes."
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/DCFCE7/22C55E?text=Técnica+do+Degradê",
                    "legenda": "Pratique o degradê de claro para escuro"
                },
                {
                    "tipo": "texto",
                    "titulo": "Sobreposição de Cores",
                    "texto": "Para criar novas cores, sobreponha camadas leves de lápis de cor diferente. Comece sempre com a cor mais clara e vá adicionando as mais escuras. Nunca pressione muito na primeira camada!"
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/DCFCE7/22C55E?text=Sobreposição+de+Cores",
                    "legenda": "Sobreposição cria cores novas e efeitos incríveis"
                }
            ],
            "ordem": 2,
            "ativo": true
        },
        {
            "id": "aula-003",
            "titulo": "Proporções do Rosto Humano",
            "descricao": "Aprenda as proporções corretas do rosto humano para desenhar personagens mais realistas.",
            "categoria_aula": "Anatomia",
            "imagem_capa": "https://placehold.co/400x300/F59E0B/FFFFFF?text=Proporções+Rosto",
            "conteudo": [
                {
                    "tipo": "texto",
                    "titulo": "A Regra dos Terços",
                    "texto": "O rosto humano pode ser dividido em três partes iguais: da testa até a sobrancelha, da sobrancelha até o nariz, e do nariz até o queixo. Use linhas guia leves para marcar essas divisões."
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/FEF3C7/F59E0B?text=Regra+dos+Terços",
                    "legenda": "Divida o rosto em três partes iguais"
                },
                {
                    "tipo": "texto",
                    "titulo": "Posição dos Olhos",
                    "texto": "Os olhos ficam na linha do meio da cabeça! Muita gente acha que ficam mais para cima, mas na verdade a testa ocupa metade do crânio. A distância entre os olhos é aproximadamente o tamanho de um olho."
                },
                {
                    "tipo": "imagem",
                    "url": "https://placehold.co/600x400/FEF3C7/F59E0B?text=Posição+dos+Olhos",
                    "legenda": "Os olhos ficam na linha do meio da cabeça"
                }
            ],
            "ordem": 3,
            "ativo": true
        }
    ],

